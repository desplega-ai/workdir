{
  "name": "workdir-cloud",
  "version": "1.0.0",
  "private": true,
  "description": "workdir control panel — website, auth, and API key issuance on Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create workdir",
    "db:migrate": "wrangler d1 execute workdir --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute workdir --local --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.91.0"
  }
}
