{
  "name": "@mv37/workdir",
  "version": "0.1.0",
  "description": "TypeScript SDK for workdir",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
